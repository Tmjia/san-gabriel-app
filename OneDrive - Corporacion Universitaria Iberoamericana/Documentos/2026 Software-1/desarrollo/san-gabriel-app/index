// ── Toast ─────────────────────────────────────
function renderToast(msg) {
  const t = document.createElement('div');
  t.className = 'toast';
  t.textContent = msg;
  document.body.appendChild(t);
  setTimeout(()=>t.remove(), 3000);
}

// ── Helpers ───────────────────────────────────
function el(tag, cls) { const e=document.createElement(tag); if(cls)e.className=cls; return e; }
function notasDeEstudiante(id) { return estado.notas.filter(n=>n.estudianteId===id); }
function promedioEst(id) {
  const ns = notasDeEstudiante(id);
  if (!ns.length) return '—';
  return (ns.reduce((s,n)=>s+n.valor,0)/ns.length).toFixed(1);
}

// ── Iniciar ───────────────────────────────────
render();
